{
	"name": "haproxy-manager",
	"version": "0.1",
	"scripts": {
		"dev:backend": "bun --filter @app/backend dev",
		"dev:frontend": "bun --filter @app/frontend dev",
		"dev": "bun --filter \"*\" dev",
		"format": "biome format --write .",
		"lint": "biome lint --fix ."
	},
	"workspaces": [
		"packages/**",
		"!packages/**/test/**",
		"!packages/**/template/**"
	],
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"elysia": "^1.4.27",
		"envalid": "^8.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"bun-types": "^1.3.10"
	}
}
