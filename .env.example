POSTGRES_PASSWORD=postgres
NODE_ENV=production

# Docker Compose reads this root file as the central env source.
API_KEY=haproxy-manager-local-api-key
# Leave empty to use same-origin (recommended for manager HTTPS at https://localhost)
VITE_BACKEND_URL=
FRONTEND_BACKEND_UPSTREAM=http://127.0.0.1:4320

BETTER_AUTH_URL=https://localhost
BETTER_AUTH_TRUSTED_ORIGINS=https://localhost,https://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4320,http://127.0.0.1:4320
# openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-in-production-please-change-this-secret

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@local.dev
DEFAULT_ADMIN_PASSWORD=admin12345

DEFAULT_NODE_NAME=docker-haproxy-localnode
DEFAULT_NODE_IP_ADDRESS=haproxy
DEFAULT_NODE_IS_LOCAL_SERVICE=true
DEFAULT_NODE_TYPE=managed
DEFAULT_NODE_LOG_STRATEGY=docker
DEFAULT_NODE_SSH_USER=root
DEFAULT_NODE_SSH_PORT=22
DEFAULT_NODE_HAPROXY_STATS_URL=http://haproxy:8404/stats
DEFAULT_NODE_HAPROXY_SOCKET_PATH=haproxy:16669
DEFAULT_NODE_HAPROXY_API_URL=http://backend:3000
DEFAULT_NODE_HAPROXY_CONFIG_PATH=/workspace/haproxy/conf.d
HAPROXY_STATS_URL=http://haproxy:8404/stats
HAPROXY_SOCKET_ENABLED=true
HAPROXY_SOCKET_PATH=haproxy:16669
HAPROXY_CONFIG_DIR=/workspace/haproxy/conf.d
HAPROXY_RELOAD_COMMAND=docker restart haproxy
HAPROXY_VALIDATE_COMMAND=docker exec haproxy haproxy -f /usr/local/etc/haproxy/conf.d -c
SSH_KEY_DIR=.runtime/ssh

# Used by backend /otel protected redirect endpoint.
OTEL_DASHBOARD_URL=http://localhost:4319